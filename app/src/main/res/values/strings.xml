    <!-- Settings -->
    <string name="settings_title">Settings</string>
    <string name="always_on_vpn">Always-on VPN &amp; kill switch</string>
    <string name="always_on_vpn_desc">Prevents traffic from leaking to the physical network when the tunnel is down, and lets the OS resurrect the VPN if Android kills the app. Both toggles must be set in Android system settings — the app cannot enforce this itself. Without always-on VPN, in-app reconnect recovery is best-effort.</string>
    <string name="always_on_vpn_instructions">For full leak protection:\n\n1. Open Android Settings\n2. Go to Network &amp; Internet → VPN\n3. Tap the gear icon next to VPN Master\n4. Enable \"Always-on VPN\"\n5. Enable \"Block connections without VPN\"\n\nStep 5 is the kill switch. Without it, traffic can leak to the physical network during reconnect backoff, on boot before the tunnel comes up, or if the tunnel fails.</string>
    <string name="open_vpn_settings">Open VPN Settings</string>
    <string name="watchdog_enabled">Connection Watchdog</string>
    <string name="watchdog_desc">Automatically reconnect on failure</string>
    <string name="watchdog_interval">Check Interval</string>
    <string name="watchdog_probe_failures">Probe Failures Before Reconnect</string>
    <string name="watchdog_probe_failures_disabled_label">Active probes: disabled (handshake-age only)</string>
    <string name="watchdog_probe_failures_desc">Active probe attempts (2s apart) on a stalled tunnel before reconnecting. Lower = faster recovery, higher = more tolerant of brief link blips. 0 disables active probing entirely; recovery falls back to handshake-age (~3min) — slower but lower battery use.</string>
    <string name="auto_connect_boot">Auto-connect on Boot</string>
    <string name="auto_connect_boot_desc">Connect VPN when device starts</string>

    <!-- Status notification toggle -->
    <string name="status_notif_title">Notification when disconnected</string>
    <string name="status_notif_desc">Show a dismissable status notification after a disconnect, so you can see VPN state at a glance and tap to reconnect. When off, the notification is removed once the VPN stops.</string>

    <!-- Battery optimization -->
    <string name="battery_opt_title">Battery optimization</string>
    <string name="battery_opt_desc_unrestricted">Battery optimization is disabled for VPN Master. The watchdog and reconnect logic can run reliably in the background.</string>
    <string name="battery_opt_desc_restricted">Battery optimization is currently active. Android may slow or kill background work, weakening reconnect recovery if the app is in the background. Always-on VPN at the OS level is the strongest protection; disabling battery optimization helps as a best-effort backup.</string>
    <string name="battery_opt_request_button">Disable battery optimization</string>
    <string name="battery_opt_open_settings">Open battery settings</string>

